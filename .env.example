# Copy this file to .env.local and fill in values.
# Never commit .env.local — it is git-ignored.

# NODE_ENV is set automatically by Next.js (development | production | test).
# Do not set it here.

# --- Example client-side variable (uncomment in env.ts to activate) ---
# NEXT_PUBLIC_BRAND_NAME=Acme Inc.

# --- Example server-side variable (uncomment in env.ts to activate) ---
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# ---- AI providers ----
# Only set the ones matching providers you use in lib/ai.ts.
# Install the matching @ai-sdk/* peer dep for each (see AGENT-SETUP.md).

# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# DEEPSEEK_API_KEY=
